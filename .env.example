# ── Supabase ──────────────────────────────────────────────────────────
# Récupère ces valeurs sur https://app.supabase.com → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Clé secrète (uniquement côté serveur)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── OpenAI ─────────────────────────────────────────────────────────────
# Récupère ta clé sur https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Stripe ─────────────────────────────────────────────────────────────
# Récupère ces valeurs sur https://dashboard.stripe.com → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRO_PRICE_ID=price_...
# Secret du webhook (Stripe Dashboard → Webhooks → ta destination → Clé secrète)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
